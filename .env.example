# Hacker News API 配置
HN_API_BASE=https://hacker-news.firebaseio.com/v0
REQUEST_TIMEOUT=10
MAX_RETRIES=3
RETRY_DELAY=2

# 文章数量配置
ARTICLE_COUNT=10
WEEKLY_TOP_COUNT=20
MONTHLY_TOP_COUNT=50

# 文件路径配置
ARCHIVES_DIR=archives
WEEKLY_DIR=weekly
MONTHLY_DIR=monthly
README_FILE=README.md

# 时区配置（UTC偏移小时数）
TIMEZONE_OFFSET=8

# 日志配置
LOG_LEVEL=INFO
